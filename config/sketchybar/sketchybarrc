#!/bin/bash
# SketchyBar — Sunset Ember
# Docs: https://felixkratz.github.io/SketchyBar/
# Reload after edits:  sketchybar --reload

PLUGIN_DIR="$CONFIG_DIR/plugins"

# --- Sunset Ember palette (single source of truth: colors.sh) ---
source "$CONFIG_DIR/colors.sh"
export BAR=0xf00a1618      # slightly translucent bar (only color not in colors.sh)

FONT="JetBrainsMono Nerd Font"

# --- Bar appearance ---
sketchybar --bar \
  height=28 \
  blur_radius=30 \
  position=top \
  sticky=on \
  padding_left=8 \
  padding_right=8 \
  color=$BAR \
  corner_radius=8 \
  y_offset=5 \
  margin=8

# --- Default item styling (flat, no background boxes) ---
sketchybar --default \
  icon.font="$FONT:Bold:13.0" \
  icon.color=$TEXT \
  label.font="$FONT:Medium:12.0" \
  label.color=$TEXT \
  background.drawing=off \
  padding_left=4 \
  padding_right=4 \
  label.padding_left=4 \
  label.padding_right=4 \
  icon.padding_left=4 \
  icon.padding_right=4

# --- LEFT: AeroSpace workspaces ---
sketchybar --add event aerospace_workspace_change

for sid in 1 2 3 4 5; do
  sketchybar --add item space.$sid left \
    --subscribe space.$sid aerospace_workspace_change \
    --set space.$sid \
      icon="●" \
      icon.font="$FONT:Bold:10.0" \
      icon.color=$SURFACE \
      label.drawing=off \
      padding_left=3 \
      padding_right=3 \
      click_script="aerospace workspace $sid" \
      script="$PLUGIN_DIR/aerospace.sh $sid"
done

# --- LEFT: focused app name ---
sketchybar --add item front_app left \
  --set front_app \
    icon.drawing=off \
    background.drawing=off \
    label.color=$BLUE \
    script="$PLUGIN_DIR/front_app.sh" \
  --subscribe front_app front_app_switched

# --- RIGHT: clock (time only) ---
sketchybar --add item clock right \
  --set clock \
    icon.drawing=off \
    label.color=$TEXT \
    update_freq=10 \
    script="$PLUGIN_DIR/clock.sh"

# --- RIGHT: wifi ---
sketchybar --add item wifi right \
  --set wifi \
    icon.color=$CYAN \
    update_freq=30 \
    script="$PLUGIN_DIR/wifi.sh"

# --- RIGHT: volume ---
sketchybar --add item volume right \
  --set volume \
    script="$PLUGIN_DIR/volume.sh" \
  --subscribe volume volume_change

# --- RIGHT: battery ---
sketchybar --add item battery right \
  --set battery \
    update_freq=120 \
    script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery system_woke power_source_change

sketchybar --update
