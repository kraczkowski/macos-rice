#!/bin/bash
# SketchyBar — Tokyo Night
# Docs: https://felixkratz.github.io/SketchyBar/
# Reload after edits:  sketchybar --reload

PLUGIN_DIR="$CONFIG_DIR/plugins"

# --- Tokyo Night palette ---
export BASE=0xff1a1b26
export BAR=0xf01a1b26      # slightly translucent bar
export TEXT=0xffc0caf5
export BLUE=0xff7aa2f7
export PURPLE=0xffbb9af7
export CYAN=0xff7dcfff
export GREEN=0xff9ece6a
export YELLOW=0xffe0af68
export RED=0xfff7768e
export SURFACE=0xff292e42

FONT="JetBrainsMono Nerd Font"

# --- Bar appearance ---
sketchybar --bar \
  height=36 \
  blur_radius=30 \
  position=top \
  sticky=on \
  padding_left=10 \
  padding_right=10 \
  color=$BAR \
  corner_radius=9 \
  y_offset=6 \
  margin=8

# --- Default item styling ---
sketchybar --default \
  icon.font="$FONT:Bold:15.0" \
  icon.color=$TEXT \
  label.font="$FONT:Bold:13.0" \
  label.color=$TEXT \
  background.color=$SURFACE \
  background.corner_radius=6 \
  background.height=26 \
  padding_left=4 \
  padding_right=4 \
  label.padding_left=4 \
  label.padding_right=8 \
  icon.padding_left=8 \
  icon.padding_right=4

# --- LEFT: AeroSpace workspaces ---
sketchybar --add event aerospace_workspace_change

for sid in 1 2 3 4 5; do
  sketchybar --add item space.$sid left \
    --subscribe space.$sid aerospace_workspace_change \
    --set space.$sid \
      background.color=$SURFACE \
      icon="$sid" \
      icon.color=$TEXT \
      label.drawing=off \
      click_script="aerospace workspace $sid" \
      script="$PLUGIN_DIR/aerospace.sh $sid"
done

# --- LEFT: focused app name ---
sketchybar --add item front_app left \
  --set front_app \
    icon.drawing=off \
    background.drawing=off \
    label.color=$BLUE \
    script="$PLUGIN_DIR/front_app.sh" \
  --subscribe front_app front_app_switched

# --- RIGHT: clock ---
sketchybar --add item clock right \
  --set clock \
    icon="" \
    icon.color=$PURPLE \
    update_freq=10 \
    script="$PLUGIN_DIR/clock.sh"

# --- RIGHT: battery ---
sketchybar --add item battery right \
  --set battery \
    update_freq=120 \
    script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery system_woke power_source_change

# --- RIGHT: volume ---
sketchybar --add item volume right \
  --set volume \
    script="$PLUGIN_DIR/volume.sh" \
  --subscribe volume volume_change

# --- RIGHT: wifi ---
sketchybar --add item wifi right \
  --set wifi \
    icon="" \
    icon.color=$CYAN \
    update_freq=30 \
    script="$PLUGIN_DIR/wifi.sh"

sketchybar --update
