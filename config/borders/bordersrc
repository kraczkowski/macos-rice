#!/bin/bash
# JankyBorders — active-window glow (Sunset Ember)
# Docs: https://github.com/FelixKratz/JankyBorders

options=(
  style=round
  width=4.0
  hidpi=on
  active_color=0xffb33219    # ember     — focused window
  inactive_color=0xff162930  # dark teal — unfocused (subtle)
)

borders "${options[@]}"
