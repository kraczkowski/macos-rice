#!/usr/bin/env bash
# Run by AeroSpace on every workspace change (exec-on-workspace-change).
#   1) notify SketchyBar so the active-workspace dot updates
#   2) restore the default audio output when leaving the showpiece (workspace 9)
#
# The showpiece (bin/showpiece) switches the default output to "Background Music"
# so cava has audio to read; it saves the previous device to $STATE. This script
# restores that device the moment you leave workspace 9, so Background Music is
# the default output — and the mic-capture indicator is lit — ONLY while the
# showpiece is on screen.
set -uo pipefail

WS="${AEROSPACE_FOCUSED_WORKSPACE:-}"
STATE="${TMPDIR:-/tmp}/rice_prev_output"

# Keep the bar's workspace highlight working.
sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE="$WS" 2>/dev/null || true

# Left the showpiece? Put the audio output back the way it was.
if [ "$WS" != "9" ] && [ -f "$STATE" ]; then
  prev="$(cat "$STATE")"
  [ -n "$prev" ] && SwitchAudioSource -t output -s "$prev" >/dev/null 2>&1 || true
  rm -f "$STATE"
fi
